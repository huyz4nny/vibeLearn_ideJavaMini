@page
@model JavaIdeMini.Pages.Auth.LoginModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng nhập - Java IDE Mini</title>
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Outfit', sans-serif;
            background: radial-gradient(circle at top left, #111827 0%, #030712 100%);
        }
    </style>
</head>
<body class="flex items-center justify-center min-h-screen text-white p-4">
    <!-- Outer Container with ambient glow -->
    <div class="relative w-full max-w-md">
        <!-- Glow effect behind container -->
        <div class="absolute -inset-1.5 rounded-3xl bg-gradient-to-r from-violet-600 to-indigo-600 opacity-30 blur-2xl transition duration-1000 group-hover:opacity-100"></div>

        <!-- Glassmorphism Card -->
        <div class="relative w-full bg-gray-950/70 backdrop-blur-2xl border border-gray-800/80 rounded-3xl p-8 shadow-2xl">
            
            <!-- Logo & Title -->
            <div class="text-center mb-8">
                <div class="inline-flex items-center justify-center p-3.5 bg-violet-600/10 border border-violet-500/20 rounded-2xl mb-4">
                    <!-- Java Coffee Cup Icon -->
                    <svg class="w-8 h-8 text-violet-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                    </svg>
                </div>
                <h1 class="text-3xl font-extrabold tracking-tight bg-gradient-to-r from-violet-400 via-fuchsia-400 to-indigo-400 bg-clip-text text-transparent">
                    Java IDE Mini
                </h1>
                <p class="text-gray-400 mt-2 text-sm">Học tập và viết code Java trực quan, nhanh chóng</p>
            </div>

            <!-- Error/Success Alerts -->
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="mb-5 p-4 bg-red-500/10 border border-red-500/20 text-red-400 text-sm rounded-2xl flex items-center gap-3 animate-pulse">
                    <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                    <span>@Model.ErrorMessage</span>
                </div>
            }
            @if (!string.IsNullOrEmpty(Model.SuccessMessage))
            {
                <div class="mb-5 p-4 bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-sm rounded-2xl flex items-center gap-3">
                    <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    <span>@Model.SuccessMessage</span>
                </div>
            }

            <!-- Form Đăng nhập Email -->
            <form method="post" class="space-y-5">
                <div>
                    <label for="Email" class="block text-xs font-semibold uppercase tracking-wider text-gray-400 mb-2">Địa chỉ Email</label>
                    <input asp-for="Email" type="email" placeholder="example@gmail.com" 
                           class="w-full bg-gray-900/50 border border-gray-800 rounded-2xl px-4 py-3.5 text-sm text-white placeholder-gray-500 focus:outline-none focus:border-violet-500 focus:ring-1 focus:ring-violet-500 transition-all duration-300" />
                    <span asp-validation-for="Email" class="text-red-400 text-xs mt-1 block"></span>
                </div>

                <div>
                    <div class="flex justify-between items-center mb-2">
                        <label for="Password" class="block text-xs font-semibold uppercase tracking-wider text-gray-400">Mật khẩu</label>
                    </div>
                    <input asp-for="Password" type="password" placeholder="••••••••" 
                           class="w-full bg-gray-900/50 border border-gray-800 rounded-2xl px-4 py-3.5 text-sm text-white placeholder-gray-500 focus:outline-none focus:border-violet-500 focus:ring-1 focus:ring-violet-500 transition-all duration-300" />
                    <span asp-validation-for="Password" class="text-red-400 text-xs mt-1 block"></span>
                </div>

                <button type="submit" 
                        class="w-full bg-gradient-to-r from-violet-600 to-indigo-600 hover:from-violet-500 hover:to-indigo-500 text-white font-semibold rounded-2xl py-3.5 transition duration-300 shadow-lg shadow-violet-600/20 active:scale-[0.98]">
                    Đăng nhập tài khoản
                </button>
            </form>

            <!-- Separator -->
            <div class="relative flex items-center justify-center my-6">
                <div class="border-t border-gray-800 w-full"></div>
                <span class="absolute bg-gray-950 px-3 text-xs uppercase tracking-wider text-gray-500">Hoặc tiếp tục với</span>
            </div>

            <!-- Google Login Button (Google OAuth) -->
            <a href="@Model.GoogleAuthUrl"
               class="w-full inline-flex items-center justify-center gap-3 bg-gray-900 hover:bg-gray-800 border border-gray-800 rounded-2xl py-3.5 transition duration-300 font-medium active:scale-[0.98]">
                <!-- Google Icon SVG -->
                <svg class="w-5 h-5" viewBox="0 0 24 24" width="24" height="24" xmlns="http://www.w3.org/2000/svg">
                    <g transform="matrix(1, 0, 0, 1, 0, 0)">
                        <path d="M21.35,11.1H12v2.7h5.38C16.88,16.27,14.65,18,12,18a6,6,0,1,1,6-6,5.89,5.89,0,0,1-.85,3.05l2.08,2.08A8.93,8.93,0,0,0,21,12,9,9,0,0,0,21.35,11.1Z" fill="#fff"/>
                        <path d="M12,21A9,9,0,0,1,3,12,9,9,0,0,1,12,3a8.88,8.88,0,0,1,6.3,2.7l-2.08,2.08A5.89,5.89,0,0,0,12,6a6,6,0,0,0,0,12,5.89,5.89,0,0,0,4.22-1.78l2.08,2.08A8.88,8.88,0,0,1,12,21Z" fill="#ea4335"/>
                        <path d="M12,3A9,9,0,0,1,18.3,5.7l-2.08,2.08A5.89,5.89,0,0,0,12,6V3Z" fill="#fbbc05"/>
                        <path d="M12,21V18a5.89,5.89,0,0,0,4.22-1.78l2.08,2.08A8.88,8.88,0,0,1,12,21Z" fill="#34a853"/>
                        <path d="M21.35,11.1H12v2.7h5.38C17,14.9,16,15.8,14.72,16.3l2.08,2.08A8.93,8.93,0,0,0,21,12Z" fill="#4285f4"/>
                    </g>
                </svg>
                <span>Đăng nhập bằng Google</span>
            </a>

            <!-- Footer / Redirect to Register -->
            <p class="text-center text-gray-500 text-sm mt-8">
                Chưa có tài khoản? 
                <a href="/Auth/Register" class="text-violet-400 hover:text-violet-300 font-semibold transition duration-150">Đăng ký ngay</a>
            </p>

        </div>
    </div>
</body>
</html>

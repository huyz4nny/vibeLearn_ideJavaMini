@{
    var isAuthenticated = Context.User.Identity?.IsAuthenticated == true;
    var fullName = Context.Items["UserFullName"]?.ToString() ?? "Khách";
    var avatarUrl = Context.Items["UserAvatarUrl"]?.ToString() ?? "";
    var userEmail = Context.Items["UserEmail"]?.ToString() ?? "";
}
<!DOCTYPE html>
<html lang="vi" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Java IDE Mini</title>
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Google Fonts: Outfit -->
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Fira+Code:wght@400;500&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Outfit', sans-serif;
            background-color: #030712; /* Slate 950 */
        }
        .code-font {
            font-family: 'Fira Code', monospace;
        }
        /* Glassmorphism scrollbar */
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }
        ::-webkit-scrollbar-track {
            background: #0b0f19;
        }
        ::-webkit-scrollbar-thumb {
            background: #1f2937;
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #374151;
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="flex flex-col min-h-screen text-gray-100">

    <!-- Header / Navbar -->
    <header class="sticky top-0 z-50 w-full bg-gray-950/70 backdrop-blur-md border-b border-gray-800/80">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-16">
                <!-- Logo -->
                <div class="flex items-center">
                    <a asp-page="/Index" class="flex items-center gap-2.5 group">
                        <div class="p-2 bg-gradient-to-br from-violet-600 to-indigo-600 rounded-xl shadow-lg shadow-violet-600/20 group-hover:scale-105 transition-transform duration-300">
                            <!-- Java Coffee Cup SVG -->
                            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                            </svg>
                        </div>
                        <span class="text-xl font-bold tracking-tight bg-gradient-to-r from-violet-400 to-indigo-400 bg-clip-text text-transparent group-hover:text-white transition duration-300">
                            Java IDE Mini
                        </span>
                    </a>
                </div>

                <!-- Navigation Links / User Profile -->
                <div class="flex items-center gap-4">
                    @if (isAuthenticated)
                    {
                        <!-- User Profile Info -->
                        <div class="flex items-center gap-3 bg-gray-900/50 border border-gray-850 px-3 py-1.5 rounded-2xl">
                            <!-- Avatar -->
                            @if (!string.IsNullOrEmpty(avatarUrl))
                            {
                                <img src="@avatarUrl" alt="Avatar" class="w-7 h-7 rounded-xl object-cover ring-1 ring-violet-500/30" />
                            }
                            else
                            {
                                <div class="w-7 h-7 rounded-xl bg-violet-600 flex items-center justify-center font-bold text-xs text-white">
                                    @fullName.Substring(0, Math.Min(1, fullName.Length)).ToUpper()
                                </div>
                            }
                            
                            <!-- FullName & Email -->
                            <div class="hidden sm:block text-left">
                                <p class="text-xs font-semibold text-gray-200">@fullName</p>
                                <p class="text-[10px] text-gray-500 truncate max-w-[120px]">@userEmail</p>
                            </div>
                        </div>

                        <!-- Đăng xuất -->
                        <a href="/Auth/Logout" 
                           class="bg-gray-900 hover:bg-gray-800 text-gray-400 hover:text-white border border-gray-800 px-4 py-2 text-sm font-semibold rounded-2xl transition duration-300 flex items-center gap-2">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
                            <span class="hidden sm:inline">Đăng xuất</span>
                        </a>
                    }
                    else
                    {
                        <!-- Chưa Đăng nhập -->
                        <a href="/Auth/Login" 
                           class="text-gray-400 hover:text-white text-sm font-semibold px-3 py-2 transition duration-300">
                            Đăng nhập
                        </a>
                        <a href="/Auth/Register" 
                           class="bg-gradient-to-r from-violet-600 to-indigo-600 hover:from-violet-500 hover:to-indigo-500 text-white px-4 py-2 text-sm font-semibold rounded-2xl transition duration-300 shadow-md shadow-violet-600/10">
                            Đăng ký
                        </a>
                    }
                </div>
            </div>
        </div>
    </header>

    <!-- Main Content Area -->
    <main class="flex-grow max-w-7xl mx-auto w-full px-4 sm:px-6 lg:px-8 py-6 flex flex-col">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="bg-gray-950/40 border-t border-gray-900/60 py-5 mt-auto">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-gray-500">
            <div>
                &copy; @DateTime.Now.Year - Java IDE Mini. Xây dựng bằng ASP.NET Core & Supabase.
            </div>
            <div class="flex items-center gap-4">
                <span>Dành cho Java Developer sang C#</span>
                <span class="text-gray-700">|</span>
                <a href="/health" class="hover:text-gray-400 transition">Hệ thống: OK</a>
            </div>
        </div>
    </footer>

    <!-- Site scripts -->
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

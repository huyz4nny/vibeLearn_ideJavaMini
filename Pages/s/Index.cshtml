@page "/s/{shortId}"
@model JavaIdeMini.Pages.s.IndexModel
@using System.Text.Encodings.Web
@{
    ViewData["Title"] = $"Xem mã nguồn {Model.SharedSnippet?.Title}";
    var authorName = Model.SharedSnippet?.UserProfile?.FullName ?? "Người dùng ẩn danh";
    var authorAvatar = Model.SharedSnippet?.UserProfile?.AvatarUrl ?? "";
    var shareId = Model.SharedSnippet?.ShareId ?? "";
}

<!-- Toast Notification -->
<div id="toast" class="fixed bottom-5 right-5 z-50 transform translate-y-10 opacity-0 transition-all duration-300 pointer-events-none">
    <div class="bg-gray-900 border border-gray-800 text-gray-200 px-5 py-3 rounded-2xl shadow-2xl flex items-center gap-3">
        <div id="toast-icon" class="p-1.5 bg-emerald-600/10 text-emerald-400 rounded-xl">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        </div>
        <span id="toast-message" class="text-sm font-medium">Thông báo</span>
    </div>
</div>

<div class="flex-grow flex flex-col bg-gray-950/40 border border-gray-900 rounded-3xl overflow-hidden backdrop-blur-xl h-[calc(100vh-140px)]">
    
    <!-- TOP TOOLBAR: File Info & Actions -->
    <div class="flex flex-wrap items-center justify-between gap-4 p-4 border-b border-gray-900 bg-gray-950/50">
        
        <!-- File Info & Author -->
        <div class="flex items-center gap-3.5">
            <div class="p-2.5 bg-gray-900/80 border border-gray-800 rounded-2xl text-lg">
                📄
            </div>
            <div>
                <h1 class="text-sm font-bold text-white flex items-center gap-2">
                    <span>@Model.SharedSnippet?.Title</span>
                    <span class="px-2 py-0.5 bg-violet-600/10 border border-violet-500/20 text-violet-400 text-[9px] font-bold rounded-lg uppercase tracking-wider">Chỉ đọc</span>
                </h1>
                <div class="flex items-center gap-1.5 mt-1 text-[10px] text-gray-500">
                    <span>Tác giả:</span>
                    @if (!string.IsNullOrEmpty(authorAvatar))
                    {
                        <img src="@authorAvatar" alt="Avatar" class="w-4 h-4 rounded-full" />
                    }
                    <span class="font-semibold text-gray-400">@authorName</span>
                    <span>•</span>
                    <span>Lưu lúc: @Model.SharedSnippet?.UpdatedAt.LocalDateTime.ToString("dd/MM/yyyy HH:mm")</span>
                </div>
            </div>
        </div>

        <!-- Action Buttons -->
        <div class="flex items-center gap-2">
            <!-- Form Fork -->
            <form method="post" asp-page-handler="Fork" asp-route-shortId="@shareId">
                <button type="submit" 
                        class="bg-gradient-to-r from-violet-600 to-indigo-600 hover:from-violet-500 hover:to-indigo-500 text-white text-xs font-bold px-4 py-2 rounded-xl transition duration-300 shadow-md shadow-violet-600/10 flex items-center gap-1.5 active:scale-95">
                    <span>🍴</span>
                    <span>Fork về Workspace</span>
                </button>
            </form>

            <!-- Copy Link -->
            <button onclick="copyLink()" 
                    class="bg-gray-900 hover:bg-gray-800 border border-gray-800 text-gray-200 text-xs font-bold px-4 py-2 rounded-xl transition duration-300 flex items-center gap-1.5 active:scale-95">
                <span>🔗</span>
                <span>Copy Link</span>
            </button>

            <!-- Back to Home -->
            <a asp-page="/Index" 
               class="bg-gray-900 hover:bg-gray-800 border border-gray-800 text-gray-400 hover:text-white text-xs font-bold px-4 py-2 rounded-xl transition duration-300 flex items-center gap-1.5 active:scale-95">
                <span>🏠</span>
                <span>Về trang chủ</span>
            </a>
        </div>
    </div>

    <!-- WORKSPACE: Monaco Editor & Sidebar File Explorer (Read-Only) with Split Resizer -->
    <div class="flex-grow flex relative overflow-hidden">
        <!-- Project File Explorer (Left Panel) -->
        <div id="left-file-panel" class="border-r border-gray-900 bg-gray-950/10 flex flex-col shrink-0" style="width: 240px; min-w: 160px; max-w: 480px;">
            <div class="p-3 border-b border-gray-900/60 flex items-center justify-between text-xs select-none">
                <span class="font-bold text-gray-400 uppercase tracking-wider text-[10px]">Cây thư mục (NetBeans)</span>
            </div>
            <!-- File list container -->
            <div id="project-files-list" class="flex-grow overflow-y-auto p-2 space-y-1 select-none">
                <!-- Sẽ render động qua JS -->
            </div>
        </div>
        
        <!-- Vertical Resizer Bar (Splitter) -->
        <div id="vertical-resizer" class="w-1.5 hover:bg-violet-600/50 bg-gray-900/60 cursor-col-resize transition-colors shrink-0 z-20"></div>
        
        <!-- Editor (Right Panel) -->
        <div class="flex-grow relative h-full">
            <div id="editor-container" class="absolute inset-0 w-full h-full"></div>
        </div>
    </div>
    
    <textarea id="hidden-project-data" class="hidden">@Model.SharedSnippet?.Code</textarea>

</div>

@section Scripts {
    <!-- Loader CDN của Monaco Editor -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.39.0/min/vs/loader.min.js"></script>
    <script>
        // Project files management
        let projectFiles = [];
        let activeFilePath = "Main.java";

        // State to keep track of collapsed folders: folderPath -> boolean
        let collapsedFolders = {};

        // Initialize projectFiles from hidden textarea
        try {
            const rawData = document.getElementById('hidden-project-data').value;
            projectFiles = JSON.parse(rawData);
            activeFilePath = projectFiles[0]?.path || "Main.java";
        } catch(e) {
            projectFiles = [
                { path: "Main.java", content: "public class Main {\n    public static void main(String[] args) {\n        System.out.println(\"Error loading code\");\n    }\n}" }
            ];
            activeFilePath = "Main.java";
        }

        // Build a hierarchical tree of files from projectFiles list
        function buildFileTree(files) {
            const root = { name: "src", type: "folder", children: {}, path: "" };
            
            files.forEach(file => {
                const parts = file.path.split('/');
                let current = root;
                let currentPath = "";
                
                parts.forEach((part, index) => {
                    currentPath = currentPath ? currentPath + "/" + part : part;
                    const isLast = index === parts.length - 1;
                    
                    if (isLast) {
                        current.children[part] = { name: part, type: "file", path: file.path };
                    } else {
                        if (!current.children[part]) {
                            current.children[part] = { name: part, type: "folder", children: {}, path: currentPath };
                        }
                        current = current.children[part];
                    }
                });
            });
            return root;
        }

        // Recursive tree node rendering (Read-only, no delete button)
        function renderTreeNode(node, depth = 0) {
            let html = '';
            
            // Sắp xếp thư mục trước, file sau
            const keys = Object.keys(node.children || {}).sort((a, b) => {
                const typeA = node.children[a].type;
                const typeB = node.children[b].type;
                if (typeA !== typeB) {
                    return typeA === 'folder' ? -1 : 1;
                }
                return a.localeCompare(b);
            });
            
            keys.forEach(key => {
                const child = node.children[key];
                const paddingLeft = depth * 12 + 8; // Thụt lề theo độ sâu
                
                if (child.type === 'folder') {
                    const isCollapsed = collapsedFolders[child.path] === true;
                    const icon = isCollapsed ? '📁' : '📂';
                    const chevron = isCollapsed ? '▶' : '▼';
                    
                    html += `
                        <div class="group flex items-center justify-between p-1 rounded-lg text-xs hover:bg-gray-900/40 text-gray-300 select-none cursor-pointer" 
                             style="padding-left: ${paddingLeft}px" 
                             onclick="toggleFolder('${child.path.replace(/'/g, "\\'")}', event)">
                            <div class="flex items-center gap-1.5 truncate">
                                <span class="text-[8px] text-gray-500 w-3 text-center">${chevron}</span>
                                <span class="text-violet-400 text-sm leading-none">${icon}</span>
                                <span class="truncate font-semibold text-gray-300" title="${child.path}">${child.name}</span>
                            </div>
                        </div>
                    `;
                    
                    if (!isCollapsed) {
                        html += renderTreeNode(child, depth + 1);
                    }
                } else {
                    const isActive = child.path === activeFilePath;
                    
                    html += `
                        <div class="group flex items-center justify-between p-1 rounded-lg text-xs cursor-pointer transition duration-150 border select-none ${
                            isActive 
                                ? 'bg-violet-950/20 text-violet-400 border-violet-500/20 font-semibold' 
                                : 'text-gray-400 hover:bg-gray-900/50 hover:text-gray-200 border-transparent'
                        }"
                             style="padding-left: ${paddingLeft + 15}px" 
                             onclick="switchActiveFile('${child.path.replace(/'/g, "\\'")}')">
                            <div class="flex items-center gap-2 truncate pr-1">
                                <span class="text-gray-500 text-xs">📄</span>
                                <span class="truncate" title="${child.path}">${child.name}</span>
                            </div>
                        </div>
                    `;
                }
            });
            
            return html;
        }

        // Toggle folder collapse state
        function toggleFolder(folderPath, event) {
            if (event) event.stopPropagation();
            collapsedFolders[folderPath] = !collapsedFolders[folderPath];
            renderFileList();
        }

        // Render project file list
        function renderFileList() {
            const listContainer = document.getElementById('project-files-list');
            if (!listContainer) return;
            
            const tree = buildFileTree(projectFiles);
            listContainer.innerHTML = renderTreeNode(tree, 0);
        }

        // Switch active file in Monaco
        function switchActiveFile(newPath) {
            if (newPath === activeFilePath) return;
            
            activeFilePath = newPath;
            const newFile = projectFiles.find(f => f.path === activeFilePath);
            if (newFile && editor) {
                editor.setValue(newFile.content);
            }
            
            renderFileList();
        }

        // Resizer panels dragging logic
        function initResizers() {
            const vResizer = document.getElementById('vertical-resizer');
            const leftPanel = document.getElementById('left-file-panel');
            
            if (vResizer && leftPanel) {
                vResizer.addEventListener('mousedown', function(e) {
                    e.preventDefault();
                    const startX = e.clientX;
                    const startWidth = leftPanel.getBoundingClientRect().width;
                    
                    function onMouseMove(e) {
                        const dx = e.clientX - startX;
                        const newWidth = Math.max(160, Math.min(480, startWidth + dx));
                        leftPanel.style.width = newWidth + 'px';
                        if (editor) editor.layout();
                    }
                    
                    function onMouseUp() {
                        document.removeEventListener('mousemove', onMouseMove);
                        document.removeEventListener('mouseup', onMouseUp);
                    }
                    
                    document.addEventListener('mousemove', onMouseMove);
                    document.addEventListener('mouseup', onMouseUp);
                });
            }
        }

        // Initialize Monaco Editor
        let editor;
        require.config({ paths: { 'vs': 'https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.39.0/min/vs' } });
        require(['vs/editor/editor.main'], function () {
            const activeFile = projectFiles.find(f => f.path === activeFilePath) || projectFiles[0];
            
            editor = monaco.editor.create(document.getElementById('editor-container'), {
                value: activeFile ? activeFile.content : '',
                language: 'java',
                theme: 'vs-dark',
                automaticLayout: true,
                fontSize: 14,
                fontFamily: "'Fira Code', monospace",
                minimap: { enabled: false },
                readOnly: true, // Chế độ chỉ đọc
                domReadOnly: true,
                cursorBlinking: "solid",
                
                // Tắt hoàn toàn gợi ý code theo yêu cầu của user
                quickSuggestions: false,
                suggestOnTriggerCharacters: false,
                wordBasedSuggestions: false,
                parameterHints: { enabled: false }
            });

            renderFileList();
            initResizers();
        });

        // Copy Share Link Function
        function copyLink() {
            navigator.clipboard.writeText(window.location.href).then(() => {
                showToast("Đã copy link chia sẻ vào clipboard!", "success");
            }).catch(err => {
                showToast("Lỗi khi copy link: " + err, "error");
            });
        }

        // Show Toast Function
        function showToast(message, type) {
            const toast = document.getElementById('toast');
            const msgSpan = document.getElementById('toast-message');
            const icon = document.getElementById('toast-icon');

            msgSpan.textContent = message;

            if (type === 'success') {
                icon.className = "p-1.5 bg-emerald-600/10 text-emerald-400 rounded-xl";
                icon.innerHTML = '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>';
            } else {
                icon.className = "p-1.5 bg-red-600/10 text-red-400 rounded-xl";
                icon.innerHTML = '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>';
            }

            toast.classList.remove('opacity-0', 'translate-y-10', 'pointer-events-none');
            
            setTimeout(() => {
                toast.classList.add('opacity-0', 'translate-y-10', 'pointer-events-none');
            }, 3000);
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <text>
            showToast("@TempData["ErrorMessage"]", "error");
            </text>
        }
    </script>
}

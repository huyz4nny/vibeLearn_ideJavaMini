@page
@model JavaIdeMini.Pages.IndexModel
@using System.Text.Encodings.Web
@{
    ViewData["Title"] = "Không gian viết code Java";
    var isAuthenticated = HttpContext.User.Identity?.IsAuthenticated == true;
    var currentSnippetId = Model.CurrentSnippet?.Id ?? 0;
    var currentSnippetShareId = Model.CurrentSnippet?.ShareId ?? "";
    var currentSnippetIsPublic = Model.CurrentSnippet?.IsPublic == true;
}

<!-- Toast Notification -->
<div id="toast" class="fixed bottom-5 right-5 z-50 transform translate-y-10 opacity-0 transition-all duration-300 pointer-events-none">
    <div class="bg-gray-900 border border-gray-800 text-gray-200 px-5 py-3 rounded-2xl shadow-2xl flex items-center gap-3">
        <div id="toast-icon" class="p-1.5 bg-violet-600/10 text-violet-400 rounded-xl">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        </div>
        <span id="toast-message" class="text-sm font-medium">Thông báo</span>
    </div>
</div>

<div class="flex-grow flex flex-col lg:flex-row gap-6 h-[calc(100vh-140px)]">
    
    <!-- SIDEBAR: Trình Quản Lý Snippets & Lịch Sử (Ẩn nếu chưa đăng nhập) -->
    @if (isAuthenticated)
    {
        <div class="w-full lg:w-80 shrink-0 flex flex-col bg-gray-950/40 border border-gray-900 rounded-3xl p-5 gap-5 backdrop-blur-xl h-full overflow-hidden">
            
            <!-- Quota Counter Widget -->
            <div class="bg-gradient-to-br from-violet-950/20 to-indigo-950/20 border border-violet-900/20 rounded-2xl p-4">
                <div class="flex justify-between items-center mb-2">
                    <span class="text-xs font-semibold uppercase tracking-wider text-gray-400">Hạn mức hàng ngày</span>
                    <span id="quota-badge" class="text-xs font-bold text-violet-400">@Model.RemainingQuota / 200</span>
                </div>
                <!-- Progress bar -->
                <div class="w-full bg-gray-900 rounded-full h-1.5 overflow-hidden">
                    <div id="quota-progress" class="bg-gradient-to-r from-violet-500 to-indigo-500 h-1.5 transition-all duration-500" 
                         style="width: @((Model.RemainingQuota / 200.0) * 100)%"></div>
                </div>
                <p class="text-[10px] text-gray-500 mt-2">Đăng nhập bằng Google giúp tăng độ bảo mật phiên làm việc.</p>
            </div>

            <!-- Sidebar Navigation Tabs -->
            <div class="flex border-b border-gray-900 p-0.5 bg-gray-950/60 rounded-xl">
                <button onclick="switchTab('snippets')" id="tab-btn-snippets" 
                        class="flex-1 text-center py-2 text-xs font-bold rounded-lg bg-gray-900 text-white transition-all duration-300">
                    Mã nguồn của tôi (@Model.UserSnippets.Count)
                </button>
                <button onclick="switchTab('history')" id="tab-btn-history" 
                        class="flex-1 text-center py-2 text-xs font-bold rounded-lg text-gray-400 hover:text-gray-200 transition-all duration-300">
                    Lịch sử chạy
                </button>
            </div>

            <!-- TAB 1: Danh sách Snippets -->
            <div id="tab-snippets" class="flex-grow overflow-y-auto space-y-2 pr-1">
                <div class="flex justify-between items-center mb-1">
                    <span class="text-xs text-gray-500">Danh sách tệp tin</span>
                    <a href="/" class="p-1 hover:bg-gray-900 text-gray-400 hover:text-white rounded-lg transition" title="Tạo tệp mới">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                    </a>
                </div>

                @if (!Model.UserSnippets.Any())
                {
                    <div class="text-center py-8 text-gray-500 text-xs">
                        <p>Bạn chưa lưu snippet nào.</p>
                        <p class="mt-1">Hãy viết code và nhấn "Lưu" để bắt đầu.</p>
                    </div>
                }
                else
                {
                    @foreach (var snippet in Model.UserSnippets)
                    {
                        var isActive = currentSnippetId == snippet.Id;
                        <div class="group flex items-center justify-between w-full p-3 rounded-xl border transition-all duration-200 @(isActive ? "bg-violet-950/10 border-violet-500/30 text-white" : "bg-gray-900/20 border-gray-900 text-gray-400 hover:bg-gray-900/50 hover:text-white")">
                            <a href="/Index?id=@snippet.Id" class="flex-grow truncate text-xs font-medium pr-2 block">
                                <div class="flex items-center gap-2">
                                    <span class="w-1.5 h-1.5 rounded-full @(snippet.IsPublic ? "bg-emerald-500" : "bg-gray-600")"></span>
                                    <span class="truncate">@snippet.Title</span>
                                </div>
                                <span class="text-[9px] text-gray-500 block mt-1">Sửa lúc: @snippet.UpdatedAt.LocalDateTime.ToString("dd/MM HH:mm")</span>
                            </a>
                            
                            <!-- Nút xóa snippet -->
                            <form method="post" asp-page-handler="DeleteSnippet" onsubmit="return confirm('Bạn chắc chắn muốn xóa file này? Hành động này không thể hoàn tác.');" class="shrink-0 opacity-0 group-hover:opacity-100 transition-opacity">
                                <input type="hidden" name="id" value="@snippet.Id" />
                                <button type="submit" class="p-1 text-gray-500 hover:text-red-400 rounded transition">
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                </button>
                            </form>
                        </div>
                    }
                }
            </div>

            <!-- TAB 2: Lịch sử chạy -->
            <div id="tab-history" class="hidden flex-grow overflow-y-auto space-y-2 pr-1">
                <span class="text-xs text-gray-500 block mb-1">20 lần chạy gần nhất</span>
                
                @if (!Model.RecentHistory.Any())
                {
                    <div class="text-center py-8 text-gray-500 text-xs">
                        Không có lịch sử chạy code gần đây.
                    </div>
                }
                else
                {
                    @foreach (var history in Model.RecentHistory)
                    {
                        <div class="p-3 bg-gray-900/20 border border-gray-900 rounded-xl hover:border-gray-800 transition cursor-pointer text-[11px] group"
                             onclick="loadHistoryCode(this)" 
                             data-code="@JavaScriptEncoder.Default.Encode(history.Code)">
                            <div class="flex justify-between items-center">
                                <span class="font-bold @(history.Status == "success" ? "text-emerald-400" : "text-red-400")">
                                    @(history.Status == "success" ? "✔ Thành công" : "✘ Lỗi compile")
                                </span>
                                <span class="text-gray-500">@history.CreatedAt.LocalDateTime.ToString("dd/MM HH:mm")</span>
                            </div>
                            <div class="text-gray-400 truncate mt-1.5 code-font">
                                @history.Code.Replace("\n", " ").Replace("\r", "")
                            </div>
                            <div class="flex justify-between text-[9px] text-gray-500 mt-1.5 pt-1.5 border-t border-gray-900/50">
                                <span>Thời gian: @(history.DurationMs)ms</span>
                                <span class="text-violet-400 group-hover:underline">Nhấp để nạp lại code</span>
                            </div>
                        </div>
                    }
                }
            </div>

        </div>
    }

    <!-- MAIN WORKSPACE: Monaco Editor & Terminal -->
    <div class="flex-grow flex flex-col bg-gray-950/40 border border-gray-900 rounded-3xl overflow-hidden backdrop-blur-xl h-full">
        
        <!-- TOP TOOLBAR: File Config, Title, Actions -->
        <div class="flex flex-wrap items-center justify-between gap-3 p-4 border-b border-gray-900 bg-gray-950/50">
            <!-- Form Lưu Snippet -->
            <form id="save-form" method="post" asp-page-handler="SaveSnippet" class="flex flex-wrap items-center gap-3 w-full sm:w-auto">
                <input type="hidden" name="id" value="@currentSnippetId" />
                
                <!-- Input Tên File -->
                <div class="relative shrink-0">
                    <span class="absolute inset-y-0 left-3 flex items-center text-gray-500 text-xs font-semibold">📁</span>
                    <input type="text" name="title" id="file-title" required placeholder="Main.java" 
                           value="@(Model.CurrentSnippet?.Title ?? "Main.java")" 
                           class="bg-gray-900/80 border border-gray-800 rounded-xl pl-8 pr-3 py-1.5 text-xs text-white placeholder-gray-500 focus:outline-none focus:border-violet-500 transition w-44" />
                </div>

                @if (isAuthenticated)
                {
                    <!-- Checkbox Public -->
                    <label class="flex items-center gap-2 cursor-pointer select-none text-xs text-gray-400 hover:text-white">
                        <input type="checkbox" name="isPublic" value="true" @(currentSnippetIsPublic ? "checked" : "")
                               class="rounded border-gray-800 text-violet-600 bg-gray-900 focus:ring-violet-500 h-4 w-4" />
                        <span>Chế độ công khai</span>
                    </label>
                }
                
                <!-- Textarea ẩn chứa code để submit form -->
                <textarea name="code" id="hidden-code-area" class="hidden"></textarea>
                <textarea id="hidden-project-data" class="hidden">@(Model.CurrentSnippet?.Code ?? Model.DefaultCode)</textarea>
            </form>

            <!-- Nút Hành Động -->
            <div class="flex items-center gap-2">
                <!-- Nút Chạy Code -->
                <button type="button" onclick="runJavaCode()" id="run-btn" 
                        class="bg-gradient-to-r from-emerald-600 to-teal-600 hover:from-emerald-500 hover:to-teal-500 text-white text-xs font-bold px-4 py-2 rounded-xl transition duration-300 shadow-md shadow-emerald-600/10 flex items-center gap-1.5 active:scale-95">
                    <span>▶</span>
                    <span>Chạy</span>
                </button>

                @if (isAuthenticated)
                {
                    <!-- Nút Lưu Snippet -->
                    <button type="button" onclick="submitSaveForm()" 
                            class="bg-gray-900 hover:bg-gray-800 border border-gray-800 text-gray-200 text-xs font-bold px-4 py-2 rounded-xl transition duration-300 flex items-center gap-1.5 active:scale-95">
                        <span>💾</span>
                        <span>@(currentSnippetId > 0 ? "Cập nhật" : "Lưu")</span>
                    </button>

                    <!-- Nút Chia Sẻ Link (Chỉ hiển thị khi đã lưu snippet thành công) -->
                    @if (!string.IsNullOrEmpty(currentSnippetShareId))
                    {
                        <button type="button" onclick="copyShareLink('@currentSnippetShareId')" 
                                class="bg-gray-900 hover:bg-gray-800 border border-gray-800 text-violet-400 hover:text-violet-300 text-xs font-bold px-4 py-2 rounded-xl transition duration-300 flex items-center gap-1.5 active:scale-95">
                            <span>🔗</span>
                            <span>Copy link chia sẻ</span>
                        </button>
                    }
                }
                else
                {
                    <!-- Nhắc nhở đăng nhập để Lưu -->
                    <a href="/Auth/Login" class="text-xs text-gray-500 hover:text-gray-300 border border-dashed border-gray-800 px-3 py-2 rounded-xl transition">
                        Đăng nhập để Lưu & Chia sẻ
                    </a>
                }
            </div>
        </div>

        <!-- CENTER WORKSPACE: Monaco Editor & Sidebar File Explorer -->
        <div class="flex-grow flex relative min-h-[300px] overflow-hidden">
            @if (!isAuthenticated)
            {
                <!-- Overlay cảnh báo nếu chưa đăng nhập -->
                <div class="absolute inset-0 bg-gray-950/80 backdrop-blur-sm z-30 flex flex-col items-center justify-center p-6 text-center">
                    <div class="max-w-md space-y-4">
                        <div class="p-3 bg-violet-600/10 border border-violet-500/20 rounded-2xl w-14 h-14 flex items-center justify-center mx-auto mb-2 text-2xl">
                            🔒
                        </div>
                        <h2 class="text-xl font-bold">Yêu cầu Đăng nhập</h2>
                        <p class="text-gray-400 text-sm">Bạn cần đăng nhập bằng tài khoản Google hoặc Email để lập trình và thực thi mã nguồn Java trực tuyến.</p>
                        <div class="pt-2 flex justify-center gap-3">
                            <a href="/Auth/Login" class="bg-gradient-to-r from-violet-600 to-indigo-600 hover:from-violet-500 hover:to-indigo-500 text-white text-xs font-bold px-5 py-2.5 rounded-xl transition shadow-lg shadow-violet-600/25">Đăng nhập</a>
                            <a href="/Auth/Register" class="bg-gray-900 hover:bg-gray-800 border border-gray-800 text-xs font-bold px-5 py-2.5 rounded-xl transition">Đăng ký tài khoản</a>
                        </div>
                    </div>
                </div>
            }
            
            <!-- Project File Explorer (Left Panel) -->
            <div class="w-64 border-r border-gray-900 bg-gray-950/10 flex flex-col shrink-0">
                <div class="p-3 border-b border-gray-900/60 flex items-center justify-between text-xs select-none">
                    <span class="font-bold text-gray-400 uppercase tracking-wider text-[10px]">Tệp tin dự án (OOP)</span>
                    @if (isAuthenticated)
                    {
                        <button onclick="addNewProjectFile()" class="p-1 hover:bg-gray-900 text-gray-400 hover:text-white rounded transition flex items-center justify-center w-5 h-5 font-bold" title="Tạo tệp Java mới">
                            +
                        </button>
                    }
                </div>
                <!-- File list container -->
                <div id="project-files-list" class="flex-grow overflow-y-auto p-2 space-y-1 select-none">
                    <!-- Sẽ render động qua JS -->
                </div>
            </div>
            
            <!-- Editor (Right Panel) -->
            <div class="flex-grow relative h-full">
                <div id="editor-container" class="absolute inset-0 w-full h-full"></div>
            </div>
        </div>

        <!-- BOTTOM TERMINAL: Simulating Terminal Output -->
        <div class="h-60 shrink-0 border-t border-gray-900 bg-gray-950 flex flex-col">
            <!-- Terminal Header -->
            <div class="bg-gray-950/80 px-4 py-2 border-b border-gray-900/60 flex items-center justify-between text-xs text-gray-500 select-none">
                <div class="flex items-center gap-2">
                    <span class="w-2.5 h-2.5 rounded-full bg-red-500/60"></span>
                    <span class="w-2.5 h-2.5 rounded-full bg-yellow-500/60"></span>
                    <span class="w-2.5 h-2.5 rounded-full bg-green-500/60"></span>
                    <span class="ml-2 font-bold uppercase tracking-wider text-[10px] text-gray-400">Kết quả chạy code (Terminal)</span>
                </div>
                <div class="flex items-center gap-4 text-[10px]">
                    <span id="terminal-timer" class="hidden">Thời gian: -- ms</span>
                    <button onclick="clearTerminal()" class="hover:text-gray-300 transition">Xóa Terminal</button>
                </div>
            </div>
            
            <!-- Terminal Output Area -->
            <div class="flex-grow p-4 overflow-y-auto bg-black text-emerald-400 code-font text-xs leading-relaxed whitespace-pre-wrap select-text selection:bg-violet-600 selection:text-white" id="terminal-output">
# Vui lòng bấm nút "▶ Chạy" ở trên để thực thi code.
# Hạn mức quota của bạn sẽ được bảo vệ bởi middleware rate-limiting.
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <!-- Loader CDN của Monaco Editor -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.39.0/min/vs/loader.min.js"></script>
    <script>
        // Tab system logic (Sidebar)
        function switchTab(tabName) {
            const btnSnippets = document.getElementById('tab-btn-snippets');
            const btnHistory = document.getElementById('tab-btn-history');
            const tabSnippets = document.getElementById('tab-snippets');
            const tabHistory = document.getElementById('tab-history');

            if (tabName === 'snippets') {
                if (btnSnippets) btnSnippets.className = "flex-1 text-center py-2 text-xs font-bold rounded-lg bg-gray-900 text-white transition-all duration-300";
                if (btnHistory) btnHistory.className = "flex-1 text-center py-2 text-xs font-bold rounded-lg text-gray-400 hover:text-gray-200 transition-all duration-300";
                if (tabSnippets) tabSnippets.classList.remove('hidden');
                if (tabHistory) tabHistory.classList.add('hidden');
            } else {
                if (btnHistory) btnHistory.className = "flex-1 text-center py-2 text-xs font-bold rounded-lg bg-gray-900 text-white transition-all duration-300";
                if (btnSnippets) btnSnippets.className = "flex-1 text-center py-2 text-xs font-bold rounded-lg text-gray-400 hover:text-gray-200 transition-all duration-300";
                if (tabHistory) tabHistory.classList.remove('hidden');
                if (tabSnippets) tabSnippets.classList.add('hidden');
            }
        }

        // Project files management
        let projectFiles = [];
        let activeFilePath = "Main.java";

        // Initialize projectFiles from hidden textarea
        try {
            const rawData = document.getElementById('hidden-project-data').value;
            projectFiles = JSON.parse(rawData);
            activeFilePath = projectFiles[0]?.path || "Main.java";
        } catch(e) {
            projectFiles = [
                { path: "Main.java", content: "public class Main {\n    public static void main(String[] args) {\n        System.out.println(\"Error loading code\");\n    }\n}" }
            ];
            activeFilePath = "Main.java";
        }

        // Render project file list
        function renderFileList() {
            const listContainer = document.getElementById('project-files-list');
            if (!listContainer) return;
            listContainer.innerHTML = '';
            
            projectFiles.forEach((file) => {
                const isActive = file.path === activeFilePath;
                
                const item = document.createElement('div');
                item.className = `group flex items-center justify-between p-2 rounded-xl cursor-pointer text-xs transition duration-150 border ${
                    isActive 
                        ? 'bg-violet-950/20 text-violet-400 border-violet-500/20 font-semibold' 
                        : 'text-gray-400 hover:bg-gray-900/50 hover:text-gray-200 border-transparent'
                }`;
                item.setAttribute('onclick', `switchActiveFile("${file.path.replace(/"/g, '&quot;')}")`);
                
                const infoDiv = document.createElement('div');
                infoDiv.className = 'flex items-center gap-2 truncate pr-2';
                
                const isSubfolder = file.path.includes('/');
                const icon = isSubfolder ? '📂' : '📄';
                
                infoDiv.innerHTML = `<span>${icon}</span><span class="truncate" title="${file.path}">${file.path}</span>`;
                item.appendChild(infoDiv);
                
                const isAuthed = @(isAuthenticated ? "true" : "false");
                if (isAuthed && file.path !== 'Main.java') {
                    const deleteBtn = document.createElement('button');
                    deleteBtn.className = 'opacity-0 group-hover:opacity-100 p-0.5 hover:text-red-400 text-gray-500 rounded transition shrink-0 font-bold text-sm';
                    deleteBtn.innerHTML = '×';
                    deleteBtn.title = 'Xóa tệp';
                    deleteBtn.onclick = (e) => {
                        e.stopPropagation();
                        deleteProjectFile(file.path);
                    };
                    item.appendChild(deleteBtn);
                }
                
                listContainer.appendChild(item);
            });
        }

        // Switch active file in Monaco
        function switchActiveFile(newPath) {
            if (newPath === activeFilePath) return;
            
            if (editor) {
                const currentContent = editor.getValue();
                const file = projectFiles.find(f => f.path === activeFilePath);
                if (file) {
                    file.content = currentContent;
                }
            }
            
            activeFilePath = newPath;
            const newFile = projectFiles.find(f => f.path === activeFilePath);
            if (newFile && editor) {
                editor.setValue(newFile.content);
            }
            
            renderFileList();
        }

        // Add new project file
        function addNewProjectFile() {
            const path = prompt("Nhập tên tệp Java mới (bao gồm cả package nếu muốn, ví dụ: animals/Dog.java hoặc MyHelper.java):");
            if (!path) return;
            
            const trimmedPath = path.trim().replace(/\\/g, '/');
            if (trimmedPath.length === 0) {
                alert("Tên tệp không được trống.");
                return;
            }
            if (!trimmedPath.endsWith('.java')) {
                alert("Tệp phải có đuôi mở rộng là .java");
                return;
            }
            if (trimmedPath === 'Main.java') {
                alert("Tệp Main.java đã tồn tại làm tệp khởi chạy chính.");
                return;
            }
            
            if (projectFiles.some(f => f.path.toLowerCase() === trimmedPath.toLowerCase())) {
                alert("Tệp này đã tồn tại trong dự án.");
                return;
            }
            
            // Generate basic template
            let pkg = "";
            let className = trimmedPath;
            const lastSlash = trimmedPath.lastIndexOf('/');
            if (lastSlash !== -1) {
                pkg = trimmedPath.substring(0, lastSlash).replace(/\//g, '.');
                className = trimmedPath.substring(lastSlash + 1);
            }
            className = className.replace('.java', '');
            
            let template = "";
            if (pkg) {
                template += `package ${pkg};\n\n`;
            }
            template += `public class ${className} {\n    // Khởi tạo các phương thức và thuộc tính cho OOP\n}\n`;
            
            projectFiles.push({
                path: trimmedPath,
                content: template
            });
            
            activeFilePath = trimmedPath;
            if (editor) {
                editor.setValue(template);
            }
            
            renderFileList();
            showToast(`Đã tạo tệp ${trimmedPath} thành công!`, 'success');
        }

        // Delete project file
        function deleteProjectFile(pathToDelete) {
            if (pathToDelete === 'Main.java') {
                alert("Không thể xóa tệp chính Main.java");
                return;
            }
            
            if (!confirm(`Bạn chắc chắn muốn xóa tệp ${pathToDelete}?`)) {
                return;
            }
            
            const index = projectFiles.findIndex(f => f.path === pathToDelete);
            if (index !== -1) {
                projectFiles.splice(index, 1);
                
                if (activeFilePath === pathToDelete) {
                    activeFilePath = 'Main.java';
                    const mainFile = projectFiles.find(f => f.path === 'Main.java');
                    if (editor && mainFile) {
                        editor.setValue(mainFile.content);
                    }
                }
                
                renderFileList();
                showToast(`Đã xóa tệp ${pathToDelete}.`, 'info');
            }
        }

        // Initialize Monaco Editor
        let editor;
        require.config({ paths: { 'vs': 'https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.39.0/min/vs' } });
        require(['vs/editor/editor.main'], function () {
            const activeFile = projectFiles.find(f => f.path === activeFilePath) || projectFiles[0];
            
            editor = monaco.editor.create(document.getElementById('editor-container'), {
                value: activeFile ? activeFile.content : '',
                language: 'java',
                theme: 'vs-dark',
                automaticLayout: true,
                fontSize: 14,
                fontFamily: "'Fira Code', monospace",
                minimap: { enabled: false },
                roundedSelection: true,
                cursorBlinking: "smooth",
                cursorSmoothCaretAnimation: "on",
                readOnly: @(isAuthenticated ? "false" : "true")
            });

            renderFileList();
        });

        // Load code from History click
        function loadHistoryCode(element) {
            const code = element.getAttribute('data-code');
            if (editor && code) {
                try {
                    const parsed = JSON.parse(code);
                    if (Array.isArray(parsed) && parsed.length > 0) {
                        projectFiles = parsed;
                        activeFilePath = projectFiles[0]?.path || 'Main.java';
                        const activeFile = projectFiles.find(f => f.path === activeFilePath);
                        editor.setValue(activeFile ? activeFile.content : '');
                        renderFileList();
                        showToast("Đã tải toàn bộ dự án từ lịch sử chạy!", "success");
                        switchTab('snippets');
                        return;
                    }
                } catch (e) {
                    // Fallback to legacy string format
                }
                
                projectFiles = [{ path: 'Main.java', content: code }];
                activeFilePath = 'Main.java';
                editor.setValue(code);
                renderFileList();
                showToast("Đã tải mã nguồn từ lịch sử chạy!", "info");
                switchTab('snippets');
            }
        }

        // Submit Save Form
        function submitSaveForm() {
            if (!editor) return;
            
            // Save current editor value
            const currentContent = editor.getValue();
            const file = projectFiles.find(f => f.path === activeFilePath);
            if (file) {
                file.content = currentContent;
            }
            
            // Submit as JSON string
            document.getElementById('hidden-code-area').value = JSON.stringify(projectFiles);
            document.getElementById('save-form').submit();
        }

        // Run Java Code via API
        function runJavaCode() {
            if (!editor) return;
            
            // Save current editor value
            const currentContent = editor.getValue();
            const file = projectFiles.find(f => f.path === activeFilePath);
            if (file) {
                file.content = currentContent;
            }

            const terminal = document.getElementById('terminal-output');
            const timer = document.getElementById('terminal-timer');
            const runBtn = document.getElementById('run-btn');

            terminal.textContent = "Đang biên dịch và chạy ứng dụng Java...\n";
            terminal.className = "flex-grow p-4 overflow-y-auto bg-black text-yellow-500 code-font text-xs leading-relaxed whitespace-pre-wrap select-text";
            timer.classList.add('hidden');
            runBtn.disabled = true;

            const snippetId = @(currentSnippetId > 0 ? currentSnippetId.ToString() : "null");

            fetch('/api/run', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    files: projectFiles,
                    snippetId: snippetId
                })
            })
            .then(async response => {
                const data = await response.json();
                
                if (response.ok) {
                    terminal.textContent = data.output;
                    terminal.className = "flex-grow p-4 overflow-y-auto bg-black text-emerald-400 code-font text-xs leading-relaxed whitespace-pre-wrap select-text";
                    
                    timer.textContent = `Thời gian: ${data.durationMs} ms`;
                    timer.classList.remove('hidden');

                    updateQuotaDisplay(data.remainingQuota);
                } else {
                    terminal.textContent = `[LỖI HỆ THỐNG - HTTP ${response.status}]\n${data.message || 'Lỗi không xác định.'}`;
                    terminal.className = "flex-grow p-4 overflow-y-auto bg-black text-red-500 code-font text-xs leading-relaxed whitespace-pre-wrap select-text";
                }
            })
            .catch(err => {
                terminal.textContent = `[LỖI KẾT NỐI]\nKhông thể kết nối đến máy chủ biên dịch: ${err.message}`;
                terminal.className = "flex-grow p-4 overflow-y-auto bg-black text-red-500 code-font text-xs leading-relaxed whitespace-pre-wrap select-text";
            })
            .finally(() => {
                runBtn.disabled = false;
            });
        }

        // Update quota widget
        function updateQuotaDisplay(remaining) {
            const badge = document.getElementById('quota-badge');
            const progress = document.getElementById('quota-progress');
            
            if (badge) badge.textContent = `${remaining} / 200`;
            if (progress) {
                const pct = (remaining / 200.0) * 100;
                progress.style.width = `${pct}%`;
            }
        }

        // Clear Terminal
        function clearTerminal() {
            const terminal = document.getElementById('terminal-output');
            terminal.textContent = "";
            document.getElementById('terminal-timer').classList.add('hidden');
        }

        // Copy Share Link
        function copyShareLink(shareId) {
            const domain = window.location.origin;
            const fullLink = `${domain}/s/${shareId}`;
            
            navigator.clipboard.writeText(fullLink).then(() => {
                showToast("Đã copy link chia sẻ vào clipboard!", "success");
            }).catch(err => {
                showToast("Lỗi khi copy link: " + err, "error");
            });
        }

        // Show toast notification
        function showToast(message, type) {
            const toast = document.getElementById('toast');
            const msgSpan = document.getElementById('toast-message');
            const icon = document.getElementById('toast-icon');

            msgSpan.textContent = message;

            if (type === 'success') {
                icon.className = "p-1.5 bg-emerald-600/10 text-emerald-400 rounded-xl";
                icon.innerHTML = '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>';
            } else if (type === 'error') {
                icon.className = "p-1.5 bg-red-600/10 text-red-400 rounded-xl";
                icon.innerHTML = '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>';
            } else {
                icon.className = "p-1.5 bg-violet-600/10 text-violet-400 rounded-xl";
                icon.innerHTML = '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>';
            }

            toast.classList.remove('opacity-0', 'translate-y-10', 'pointer-events-none');
            
            setTimeout(() => {
                toast.classList.add('opacity-0', 'translate-y-10', 'pointer-events-none');
            }, 3000);
        }

        // Display tempdata alert from server redirect
        @if (TempData["SuccessMessage"] != null)
        {
            <text>
            showToast("@TempData["SuccessMessage"]", "success");
            </text>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <text>
            showToast("@TempData["ErrorMessage"]", "error");
            </text>
        }
    </script>
}
